<!--
  About: Small photo + 2-3 sentences.
  Tech keywords are woven into prose — replaces the skills icon grid.
  ATS systems and recruiters both scan this text.
-->
<section class="section" id="about">
  <h2 class="heading-section">About</h2>
  <div class="about-grid">
    <img
      class="about-photo"
      src="/images/profile.webp"
      alt="Luis Rodriguez"
      width="80"
      height="80"
      loading="lazy"
      decoding="async"
    />
    <div class="about-text">
      <p>
        I'm a full-stack software engineer based in Tokyo. I build web
        applications with <strong>React</strong>,
        <strong>TypeScript</strong>, and <strong>Next.js</strong> on the
        front end, and <strong>Node.js</strong>,
        <strong>Python</strong>, and <strong>PostgreSQL</strong> on the
        back end. I've shipped production apps using
        <strong>AWS</strong>, <strong>Supabase</strong>, and
        <strong>Docker</strong>.
      </p>
      <p style="margin-top: 12px;">
        I care about clean code, fast interfaces, and solving real
        problems. Currently open to full-time opportunities.
      </p>
    </div>
  </div>
</section>